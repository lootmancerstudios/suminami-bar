#!/bin/bash
# Increase volume by 1%, cap at 150%
current=$(pactl get-sink-volume @DEFAULT_SINK@ 2>/dev/null | grep -oP '\d+(?=%)' | head -1)
# Default to 0 if pactl gave nothing (no sink / PipeWire not ready) so the
# numeric comparison below doesn't throw "integer expression expected".
[ -z "$current" ] && current=0
[ "$current" -lt 150 ] && pactl set-sink-volume @DEFAULT_SINK@ +1%
