#!/bin/bash
# Audio widget with styled tooltip

# Source theme colors
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "$SCRIPT_DIR/colors.sh" 2>/dev/null || {
    COLOR_ACCENT="#D27E99"
    COLOR_FG="#DCD7BA"
    COLOR_MUTED="#727169"
    COLOR_SYSTEM="#98BB6C"
    COLOR_AUDIO="#7FB4CA"
    COLOR_WARNING="#E6C384"
    COLOR_CRITICAL="#E46876"
}

# Theme colors
accent="$COLOR_ACCENT"
blue="$COLOR_AUDIO"
gray="$COLOR_MUTED"
white="$COLOR_FG"
yellow="$COLOR_WARNING"
red="$COLOR_CRITICAL"
green="$COLOR_SYSTEM"

# Check for pactl
if ! command -v pactl &>/dev/null; then
    echo '{"text": "", "tooltip": "", "class": "none"}'
    exit 0
fi

# Get default sink
sink=$(pactl get-default-sink 2>/dev/null)
if [ -z "$sink" ]; then
    echo '{"text": "ó°ťź", "tooltip": "No audio device", "class": "muted"}'
    exit 0
fi

# Get sink info
sink_info=$(pactl list sinks 2>/dev/null | grep -A 50 "Name: $sink")

# Get volume (average of channels)
volume=$(echo "$sink_info" | grep -oP 'Volume:.*?(\d+)%' | head -1 | grep -oP '\d+%' | head -1 | tr -d '%')
[ -z "$volume" ] && volume=0

# Check if muted
muted=$(echo "$sink_info" | grep -oP 'Mute: \K\w+')

# Get device description
description=$(echo "$sink_info" | grep -oP 'Description: \K.*' | head -1)
[ -z "$description" ] && description="$sink"

# Truncate long descriptions
[ ${#description} -gt 30 ] && description="${description:0:27}..."

# Icon and class based on state
if [ "$muted" = "yes" ]; then
    icon="ó°ťź"
    class="muted"
    vol_color="$gray"
else
    if [ "$volume" -ge 70 ]; then
        icon="ó°•ľ"
    elif [ "$volume" -ge 30 ]; then
        icon="ó°–€"
    else
        icon="ó°•ż"
    fi
    class=""
    vol_color="$white"
    [ "$volume" -gt 100 ] && vol_color="$yellow"
fi

# Get input (microphone) info
source=$(pactl get-default-source 2>/dev/null)
mic_info=""
if [ -n "$source" ]; then
    source_info=$(pactl list sources 2>/dev/null | grep -A 50 "Name: $source")
    mic_vol=$(echo "$source_info" | grep -oP 'Volume:.*?(\d+)%' | head -1 | grep -oP '\d+%' | head -1 | tr -d '%')
    mic_muted=$(echo "$source_info" | grep -oP 'Mute: \K\w+')
    mic_desc=$(echo "$source_info" | grep -oP 'Description: \K.*' | head -1)

    if [ -n "$mic_vol" ]; then
        if [ "$mic_muted" = "yes" ]; then
            mic_icon="ó°Ť­"
            mic_color="$gray"
        else
            mic_icon="ó°Ť¬"
            mic_color="$white"
        fi
        [ ${#mic_desc} -gt 30 ] && mic_desc="${mic_desc:0:27}..."
        mic_info="\n\n<span color='$accent'><b>Microphone</b></span>"
        mic_info="$mic_info\n<span color='$mic_color'>$mic_icon ${mic_vol}%</span>"
        [ -n "$mic_desc" ] && mic_info="$mic_info\n<span color='$gray'>$mic_desc</span>"
    fi
fi

# Build tooltip
tooltip="<span color='$accent'><b>Audio Output</b></span>"
if [ "$muted" = "yes" ]; then
    tooltip="$tooltip\n<span color='$gray'>ó°ťź Muted</span>"
else
    tooltip="$tooltip\n<span color='$vol_color'>ó°•ľ ${volume}%</span>"
fi
tooltip="$tooltip\n<span color='$gray'>$description</span>"
tooltip="$tooltip\n"
tooltip="$tooltip\n<span color='$gray'>Click to mute â€˘ Right-click for mixer</span>"
tooltip="$tooltip\n<span color='$gray'>Scroll to adjust volume</span>"
tooltip="$tooltip$mic_info"

# Text output
if [ "$muted" = "yes" ]; then
    text="$icon"
else
    text="$icon ${volume}%"
fi

echo "{\"text\": \"$text\", \"tooltip\": \"$tooltip\", \"class\": \"$class\"}"
