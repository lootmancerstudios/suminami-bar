#!/bin/bash
# CPU temperature using lm_sensors

# Source theme colors
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "$SCRIPT_DIR/colors.sh" 2>/dev/null || {
    COLOR_ACCENT="#D27E99"
    COLOR_FG="#DCD7BA"
    COLOR_MUTED="#727169"
    COLOR_SYSTEM="#98BB6C"
    COLOR_AUDIO="#7FB4CA"
    COLOR_WARNING="#E6C384"
    COLOR_CRITICAL="#E46876"
}

# Theme colors
accent="$COLOR_ACCENT"
blue="$COLOR_AUDIO"
gray="$COLOR_MUTED"
white="$COLOR_FG"
yellow="$COLOR_WARNING"
red="$COLOR_CRITICAL"
green="$COLOR_SYSTEM"

output=$(sensors 2>/dev/null)

# Main display temp (CPU Package)
temp=$(echo "$output" | awk '/Package id 0/{gsub(/[+°C]/,"",$4); print int($4)}')
[ -z "$temp" ] && temp=$(echo "$output" | awk '/Core 0/{gsub(/[+°C]/,"",$3); print int($3)}')
[ -z "$temp" ] && exit 1

class=""
[ "$temp" -ge 70 ] && class="warning"
[ "$temp" -ge 85 ] && class="critical"

# Color temp based on value
temp_color="$green"
[ "$temp" -ge 60 ] && temp_color="$white"
[ "$temp" -ge 70 ] && temp_color="$yellow"
[ "$temp" -ge 85 ] && temp_color="$red"

# Build tooltip with key sensors
tooltip="<span color='$accent'><b>CPU Package:</b></span> <span color='$temp_color'>${temp}°C</span>"

core0=$(echo "$output" | awk '/Core 0:/{gsub(/[+°C]/,"",$3); print int($3)}')
core1=$(echo "$output" | awk '/Core 1:/{gsub(/[+°C]/,"",$3); print int($3)}')
[ -n "$core0" ] && tooltip="$tooltip\n<span color='$gray'>Core 0:</span> <span color='$white'>${core0}°C</span>"
[ -n "$core1" ] && tooltip="$tooltip\n<span color='$gray'>Core 1:</span> <span color='$white'>${core1}°C</span>"

# SSD/HDD (Apple TH0A)
ssd=$(echo "$output" | awk '/TH0A:/{gsub(/[+°C]/,"",$2); print int($2)}')
[ -n "$ssd" ] && [ "$ssd" -gt 0 ] && tooltip="$tooltip\n\n<span color='$gray'>SSD:</span> <span color='$white'>${ssd}°C</span>"

# Battery
bat=$(echo "$output" | awk '/BAT0/,/temp:/{if(/temp:/) {gsub(/[+°C]/,"",$2); print int($2)}}')
[ -n "$bat" ] && tooltip="$tooltip\n<span color='$gray'>Battery:</span> <span color='$white'>${bat}°C</span>"

# Fan
fan=$(echo "$output" | awk '/Exhaust/{gsub(/:/, "", $2); print $2}')
[ -n "$fan" ] && tooltip="$tooltip\n\n<span color='$blue'>󰈐 ${fan} RPM</span>"

# Power profile (for read-only backends like TLP/auto-cpufreq)
get_power_profile() {
    # TLP
    if command -v tlp &>/dev/null && systemctl is-active tlp &>/dev/null 2>/dev/null; then
        local mode=$(tlp-stat -s 2>/dev/null | grep "^Mode" | awk '{print $3}')
        case "$mode" in
            AC) echo "Performance|TLP|$yellow" ;;
            battery) echo "Power Saver|TLP|$green" ;;
            *) echo "Balanced|TLP|$blue" ;;
        esac
        return
    fi
    # auto-cpufreq
    if command -v auto-cpufreq &>/dev/null && systemctl is-active auto-cpufreq &>/dev/null 2>/dev/null; then
        echo "Auto|auto-cpufreq|$blue"
        return
    fi
    # power-profiles-daemon is interactive, handled separately
    echo ""
}

# Only show power profile if it's a read-only backend
# (power-profiles-daemon gets its own clickable module)
if ! command -v powerprofilesctl &>/dev/null || ! systemctl is-active power-profiles-daemon &>/dev/null 2>/dev/null; then
    power_info=$(get_power_profile)
    if [ -n "$power_info" ]; then
        IFS='|' read -r pmode pmanager pcolor <<< "$power_info"
        tooltip="$tooltip\n"
        tooltip="$tooltip\n<span color='$accent'><b>Power Mode</b></span>"
        tooltip="$tooltip\n<span color='$gray'>Profile:</span> <span color='$pcolor'>$pmode</span>"
        tooltip="$tooltip\n<span color='$gray'>Manager:</span> <span color='$white'>$pmanager</span>"
    fi
fi

echo "{\"text\": \"󰔏 ${temp}°\", \"class\": \"$class\", \"tooltip\": \"$tooltip\"}"
