#!/bin/bash
# Bluetooth device picker using wofi

# Check for custom command override
CONFIG_FILE="$HOME/.config/waybar/suminami.conf"
if [ -f "$CONFIG_FILE" ]; then
    custom_cmd=$(grep "^bluetooth_click_command=" "$CONFIG_FILE" | cut -d'=' -f2-)
    if [ -n "$custom_cmd" ]; then
        # Run through a shell so a command with args/quoting works (and a path
        # with spaces doesn't word-split into a bogus command name).
        exec sh -c "$custom_cmd"
    fi
fi

# Get paired devices
get_paired_devices() {
    bluetoothctl --timeout 5 devices Paired 2>/dev/null | while read -r _ mac name; do
        # Check if connected
        if bluetoothctl --timeout 5 info "$mac" 2>/dev/null | grep -q "Connected: yes"; then
            echo "у°‚±  $name|disconnect:$mac"
        else
            echo "у°‚Ї  $name|connect:$mac"
        fi
    done
}

# Get discovered but unpaired devices
get_discovered_devices() {
    # Get all devices, exclude paired ones
    paired=$(bluetoothctl --timeout 5 devices Paired 2>/dev/null | awk '{print $2}')
    bluetoothctl --timeout 5 devices 2>/dev/null | while read -r _ mac name; do
        # Skip if paired
        echo "$paired" | grep -q "$mac" && continue
        echo "у°‚І  $name (new)|pair:$mac"
    done
}

# Build menu
menu=""

# Paired devices section
paired=$(get_paired_devices)
if [ -n "$paired" ]; then
    menu="$paired"
fi

# Discovered devices section
discovered=$(get_discovered_devices)
if [ -n "$discovered" ]; then
    [ -n "$menu" ] && menu="$menu\n"
    menu="$menu$discovered"
fi

# Add options
[ -n "$menu" ] && menu="$menu\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ|separator"
menu="${menu}\nу°‘“  Scan for devices|scan"
menu="${menu}\nу°њ‰  Toggle Bluetooth|toggle"

# Show menu (prefer wofi, fall back to rofi, like wifi-picker)
if command -v wofi &>/dev/null; then
    choice=$(echo -e "$menu" | wofi --show dmenu --prompt "Bluetooth" --cache-file /dev/null | tail -1)
elif command -v rofi &>/dev/null; then
    choice=$(echo -e "$menu" | rofi -dmenu -p "Bluetooth" | tail -1)
else
    notify-send "Bluetooth" "No menu tool found (install wofi or rofi)"
    exit 1
fi

[ -z "$choice" ] && exit 0

# Parse action
action=$(echo "$choice" | cut -d'|' -f2)

case "$action" in
    connect:*)
        mac="${action#connect:}"
        notify-send "Bluetooth" "Connecting..." -t 2000
        bluetoothctl --timeout 15 connect "$mac" && notify-send "Bluetooth" "Connected" -t 2000 || notify-send "Bluetooth" "Connection failed" -t 2000
        ;;
    disconnect:*)
        mac="${action#disconnect:}"
        bluetoothctl --timeout 10 disconnect "$mac" && notify-send "Bluetooth" "Disconnected" -t 2000
        ;;
    pair:*)
        mac="${action#pair:}"
        notify-send "Bluetooth" "Pairing..." -t 2000
        if bluetoothctl --timeout 15 pair "$mac"; then
            bluetoothctl --timeout 5 trust "$mac"
            notify-send "Bluetooth" "Paired successfully. Connecting..." -t 2000
            bluetoothctl --timeout 15 connect "$mac"
        else
            notify-send "Bluetooth" "Pairing failed" -t 2000
        fi
        ;;
    scan)
        notify-send "Bluetooth" "Scanning for 8 seconds..." -t 2000
        # Run scan with timeout
        bluetoothctl --timeout 8 scan on &>/dev/null
        notify-send "Bluetooth" "Scan complete" -t 2000
        # Re-open picker
        exec "$0"
        ;;
    toggle)
        powered=$(bluetoothctl --timeout 5 show | grep "Powered:" | awk '{print $2}')
        if [ "$powered" = "yes" ]; then
            bluetoothctl --timeout 5 power off && notify-send "Bluetooth" "Powered off" -t 2000
        else
            bluetoothctl --timeout 5 power on && notify-send "Bluetooth" "Powered on" -t 2000
        fi
        ;;
    separator)
        exit 0
        ;;
esac
