#!/usr/bin/env python3
"""
WiFi picker for SumiNami Bar.

Auto-detects a backend (NetworkManager via nmcli, then iwd via iwctl) and shows
a wofi/rofi menu to connect / disconnect / rescan.

Designed to NEVER fail silently: a missing tool (e.g. iwgetid/wireless_tools not
installed) or any other error raises a desktop notification telling the user what
to do, instead of the click appearing to do nothing.

Override entirely with `wifi_click_command=` in ~/.config/waybar/suminami.conf.
"""

import os
import re
import shutil
import subprocess
import sys

# Strip terminal colour codes from iwctl output before parsing.
ANSI = re.compile(r'\x1b\[[0-9;?]*[ -/]*[@-~]')


def notify(summary, body='', timeout=4000):
    """Desktop notification; also echo to stderr in case notify-send is absent."""
    if shutil.which('notify-send'):
        subprocess.run(['notify-send', '-t', str(timeout), summary, body])
    sys.stderr.write(f'wifi-picker: {summary} {body}\n'.rstrip() + '\n')


def run(args, timeout=None):
    """subprocess.run that never raises on a missing binary or a hang.

    Returns a CompletedProcess; a missing binary yields returncode 127 and a
    timeout yields 124, so callers can branch on it instead of crashing.
    """
    try:
        return subprocess.run(args, capture_output=True, text=True, timeout=timeout)
    except FileNotFoundError:
        return subprocess.CompletedProcess(args, 127, '', f'{args[0]}: not found')
    except subprocess.TimeoutExpired:
        return subprocess.CompletedProcess(args, 124, '', f'{args[0]}: timed out')


def have(binary):
    return shutil.which(binary) is not None


def check_custom_command():
    """User-defined override from suminami.conf, or None."""
    cfg = os.path.expanduser('~/.config/waybar/suminami.conf')
    try:
        with open(cfg) as f:
            for line in f:
                if line.startswith('wifi_click_command='):
                    cmd = line.split('=', 1)[1].strip()
                    if cmd:
                        return cmd
    except OSError:
        pass
    return None


def wifi_iface():
    """First wireless interface name from sysfs, or None."""
    base = '/sys/class/net'
    try:
        for dev in sorted(os.listdir(base)):
            if os.path.isdir(os.path.join(base, dev, 'wireless')):
                return dev
    except OSError:
        pass
    return None


def signal_icon(strength):
    if strength >= 80:
        return '󰤨'
    elif strength >= 60:
        return '󰤥'
    elif strength >= 40:
        return '󰤢'
    elif strength >= 20:
        return '󰤟'
    return '󰤯'


def menu(input_text):
    """Show a dmenu-style picker; prefer wofi (the bar default), fall back to rofi."""
    for cmd in (['wofi', '--dmenu', '--prompt', 'WiFi', '--cache-file', '/dev/null'],
                ['rofi', '-dmenu', '-cycle', '-p', 'WiFi']):
        try:
            return subprocess.run(cmd, input=input_text, capture_output=True, text=True)
        except FileNotFoundError:
            continue
    notify('WiFi', 'No menu tool found (install wofi or rofi)')
    sys.exit(1)


def menu_password(prompt):
    """Prompt for a password with hidden input via wofi or rofi."""
    for cmd in (['wofi', '--dmenu', '--password', '--prompt', prompt, '--cache-file', '/dev/null'],
                ['rofi', '-dmenu', '-password', '-p', prompt]):
        try:
            r = subprocess.run(cmd, input='', capture_output=True, text=True)
        except FileNotFoundError:
            continue
        if r.returncode != 0:
            return None
        return r.stdout.strip() or None
    return None


class NmcliBackend:
    """NetworkManager backend."""
    name = 'NetworkManager'

    @staticmethod
    def detect():
        return NmcliBackend() if have('nmcli') else None

    def current_ssid(self):
        r = run(['nmcli', '-t', '-f', 'active,ssid', 'dev', 'wifi'])
        for line in r.stdout.splitlines():
            parts = _nmcli_split(line)
            if len(parts) >= 2 and parts[0] == 'yes':
                return parts[1]
        return None

    def networks(self):
        r = run(['nmcli', '-t', '-f', 'active,ssid,signal,security', 'dev', 'wifi'])
        nets = {}
        for line in r.stdout.splitlines():
            parts = _nmcli_split(line)
            if len(parts) < 4 or not parts[1]:
                continue
            active, ssid, signal, security = parts[0], parts[1], parts[2], parts[3]
            try:
                signal = int(signal)
            except ValueError:
                signal = 0
            secure = bool(security and security != '--')
            is_active = (active == 'yes')
            if ssid not in nets or signal > nets[ssid][0]:
                nets[ssid] = (signal, secure, is_active)
        return _sorted_nets(nets)

    def connect(self, ssid, secure):
        # Known connection profile first (no password needed).
        if run(['nmcli', 'con', 'up', ssid]).returncode == 0:
            return True, ''
        # Otherwise associate as a new network.
        r = run(['nmcli', 'dev', 'wifi', 'connect', ssid])
        if r.returncode == 0:
            return True, ''
        if secure:
            pw = menu_password(f'Password for {ssid}')
            if pw:
                r = run(['nmcli', 'dev', 'wifi', 'connect', ssid, 'password', pw])
                return r.returncode == 0, r.stderr.strip()
        return False, r.stderr.strip()

    def disconnect(self, ssid):
        run(['nmcli', 'con', 'down', ssid])

    def rescan(self):
        run(['nmcli', 'dev', 'wifi', 'rescan'])


class IwdBackend:
    """iwd backend (iwctl)."""
    name = 'iwd'

    def __init__(self, iface):
        self.iface = iface

    @staticmethod
    def detect():
        if not have('iwctl'):
            return None
        iface = wifi_iface()
        return IwdBackend(iface) if iface else None

    def current_ssid(self):
        out = ANSI.sub('', run(['iwctl', 'station', self.iface, 'show']).stdout)
        for line in out.splitlines():
            m = re.match(r'\s*Connected network\s+(.+?)\s*$', line)
            if m:
                return m.group(1).strip()
        return None

    def networks(self):
        out = ANSI.sub('', run(
            ['iwctl', 'station', self.iface, 'get-networks', 'rssi-dbms']).stdout)
        current = self.current_ssid()
        nets = {}
        for raw in out.splitlines():
            line = raw.rstrip()
            stripped = line.strip()
            if not stripped or set(stripped) <= set('-'):
                continue
            if 'Available networks' in line or (
                    'Network name' in line and 'Security' in line):
                continue
            m = re.match(r'\s*(>?)\s*(.+?)\s+(open|psk|wep|8021x)\s+(-?\d+)\s*$', line)
            if m:
                marker, ssid, _sec, dbm = m.groups()
                dbm = int(dbm)
                secure = (_sec != 'open')
            else:
                toks = stripped.split()
                if len(toks) < 3:
                    continue
                marker = '>' if toks[0] == '>' else ''
                if marker:
                    toks = toks[1:]
                try:
                    dbm = int(toks[-1])
                except ValueError:
                    continue
                secure = (toks[-2] != 'open')
                ssid = ' '.join(toks[:-2])
            if not ssid:
                continue
            # iwd reports RSSI in dBm; map to a rough 0-100%.
            strength = max(0, min(100, 2 * (dbm + 100)))
            is_active = bool(marker) or (ssid == current)
            if ssid not in nets or strength > nets[ssid][0]:
                nets[ssid] = (strength, secure, is_active)
        return _sorted_nets(nets)

    def connect(self, ssid, secure):
        # Try a quick connect (works for already-known networks).
        if run(['iwctl', 'station', self.iface, 'connect', ssid],
               timeout=10).returncode == 0:
            return True, ''
        if secure:
            pw = menu_password(f'Password for {ssid}')
            if pw:
                r = run(['iwctl', '--passphrase', pw, 'station', self.iface,
                         'connect', ssid], timeout=20)
                return r.returncode == 0, r.stderr.strip()
        return False, 'connection failed'

    def disconnect(self, ssid):
        run(['iwctl', 'station', self.iface, 'disconnect'])

    def rescan(self):
        run(['iwctl', 'station', self.iface, 'scan'])


def _nmcli_split(line):
    """Split an nmcli -t line on unescaped ':' and unescape the fields."""
    parts = re.split(r'(?<!\\):', line)
    return [p.replace('\\:', ':') for p in parts]


def _sorted_nets(nets):
    """dict{ssid: (strength, secure, is_active)} -> list sorted by strength desc."""
    return [(ssid, v[0], v[1], v[2])
            for ssid, v in sorted(nets.items(), key=lambda x: -x[1][0])]


def main():
    custom = check_custom_command()
    if custom:
        subprocess.run(custom, shell=True)
        return

    backend = NmcliBackend.detect() or IwdBackend.detect()
    if backend is None:
        notify('WiFi', 'No supported backend found.\n'
               'Install networkmanager (nmcli) or iwd (iwctl), or set '
               'wifi_click_command= in ~/.config/waybar/suminami.conf')
        return

    current = backend.current_ssid()
    networks = backend.networks()

    # Each entry: (display label, action). Actions carrying an SSID use a tab
    # delimiter so SSIDs containing spaces/colons survive the round-trip.
    entries = []
    if current:
        entries.append((f'󰖪  Disconnect from {current}', 'disconnect'))
    entries.append(('󰑓  Rescan networks', 'rescan'))
    entries.append(('─────────────────────────', 'separator'))

    if networks:
        for ssid, strength, secure, is_active in networks:
            sec = '󰒃' if secure else '󰒄'
            if is_active:
                entries.append(
                    (f'󰤨  {ssid}  {strength}%  {sec}  (connected)', 'connected'))
            else:
                entries.append(
                    (f'{signal_icon(strength)}  {ssid}  {strength}%  {sec}',
                     f'connect\t{ssid}\t{int(secure)}'))
    else:
        entries.append(('󰤭  No networks found', 'none'))

    r = menu('\n'.join(label for label, _ in entries))
    if r.returncode != 0 or not r.stdout.strip():
        return

    selected = r.stdout.strip()
    action = next((a for label, a in entries if label == selected), None)
    if not action or action in ('separator', 'none', 'connected'):
        return

    if action == 'disconnect':
        backend.disconnect(current)
        notify('WiFi', f'Disconnected from {current}', 2000)
    elif action == 'rescan':
        notify('WiFi', 'Scanning…', 1000)
        backend.rescan()
        subprocess.Popen([sys.executable, os.path.abspath(__file__)])
    elif action.startswith('connect\t'):
        _, ssid, sec_flag = action.split('\t', 2)
        notify('WiFi', f'Connecting to {ssid}…', 2000)
        ok, err = backend.connect(ssid, sec_flag == '1')
        if ok:
            notify('WiFi', f'Connected to {ssid}', 2000)
        else:
            notify('WiFi', f'Failed to connect to {ssid}'
                   + (f'\n{err}' if err else ''))


if __name__ == '__main__':
    try:
        main()
    except Exception as exc:  # never let the click silently do nothing
        notify('WiFi picker error', str(exc))
        sys.exit(1)
