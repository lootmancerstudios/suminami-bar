#!/usr/bin/env python3
"""Weather widget for Waybar using wttr.in (auto-detects location via IP)

Caches successful results for 10 minutes. On failure, retries every interval.
Location name resolved via Nominatim (OpenStreetMap), cached for 1 hour.
"""

import json
import os
import time
import urllib.parse
import urllib.request

CACHE_FILE = "/tmp/waybar-weather-cache"
LOCATION_CACHE_FILE = "/tmp/waybar-weather-location"
CACHE_MAX_AGE = 600       # 10 minutes - only fetch weather if cache older than this
LOCATION_MAX_AGE = 3600   # 1 hour - re-geocode in case user has travelled
SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
COLORS_FILE = os.path.join(SCRIPT_DIR, "colors.sh")
CONFIG_FILE = os.path.expanduser("~/.config/waybar/suminami.conf")

def load_theme_colors():
    colors = {
        "accent": "#D27E99",
        "fg": "#DCD7BA",
        "muted": "#727169",
        "system": "#98BB6C",
        "audio": "#7FB4CA",
        "highlight": "#7FB4CA",
        "weather": "#A3D4D5",
        "warning": "#E6C384",
        "critical": "#E46876",
    }
    try:
        if os.path.exists(COLORS_FILE):
            with open(COLORS_FILE, 'r') as f:
                for line in f:
                    line = line.strip()
                    if line.startswith("COLOR_"):
                        parts = line.split("=", 1)
                        if len(parts) == 2:
                            key = parts[0].replace("COLOR_", "").lower()
                            value = parts[1].strip('"\'')
                            colors[key] = value
    except Exception:
        pass
    return colors

def load_cache():
    try:
        if os.path.exists(CACHE_FILE):
            mtime = os.path.getmtime(CACHE_FILE)
            if time.time() - mtime < CACHE_MAX_AGE:
                with open(CACHE_FILE, 'r') as f:
                    data = json.load(f)
                    if data.get("success"):
                        return data
    except Exception:
        pass
    return None

def save_cache(data):
    try:
        with open(CACHE_FILE, 'w') as f:
            json.dump(data, f)
    except Exception:
        pass

def get_weather_location():
    """Read weather_location from suminami.conf (user-configured, takes priority)"""
    try:
        if os.path.exists(CONFIG_FILE):
            with open(CONFIG_FILE, 'r') as f:
                for line in f:
                    if line.startswith('weather_location='):
                        location = line.split('=', 1)[1].strip()
                        if location:
                            return location
    except Exception:
        pass
    return None

def load_location_cache():
    """Load cached city name from Nominatim if still fresh (1 hour TTL)"""
    try:
        if os.path.exists(LOCATION_CACHE_FILE):
            mtime = os.path.getmtime(LOCATION_CACHE_FILE)
            if time.time() - mtime < LOCATION_MAX_AGE:
                with open(LOCATION_CACHE_FILE, 'r') as f:
                    return f.read().strip()
    except Exception:
        pass
    return None

def save_location_cache(city):
    try:
        with open(LOCATION_CACHE_FILE, 'w') as f:
            f.write(city)
    except Exception:
        pass

def reverse_geocode(lat, lon):
    """Resolve lat/lon to city name via Nominatim (OpenStreetMap). 1 req/sec limit."""
    try:
        url = f"https://nominatim.openstreetmap.org/reverse?lat={lat}&lon={lon}&format=json"
        req = urllib.request.Request(url, headers={"User-Agent": "suminami-waybar/1.0"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read().decode())
            addr = data.get("address", {})
            # Prefer city, then town, then village, then county
            city = (addr.get("city")
                    or addr.get("town")
                    or addr.get("village")
                    or addr.get("county")
                    or "")
            return city
    except Exception:
        return None

def parse_latlon(query_str):
    """Parse 'Lat 49.88 and Lon -97.17' from wttr.in request query"""
    try:
        parts = query_str.split()
        lat = float(parts[1])
        lon = float(parts[4])
        return lat, lon
    except Exception:
        return None, None

def fetch_weather():
    """Fetch weather from wttr.in"""
    try:
        location = get_weather_location()
        if location:
            location = urllib.parse.quote(location)
            url = f"https://wttr.in/{location}?format=j1"
        else:
            url = "https://wttr.in/?format=j1"
        req = urllib.request.Request(url, headers={"User-Agent": "curl/8.0"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            result = json.loads(resp.read().decode())
            return result.get("data", result)
    except Exception:
        return None

def get_icon(code):
    code = int(code)
    icons = {
        113: "󰖙",  # Clear/Sunny
        116: "󰖕",  # Partly cloudy
        119: "󰖐",  # Cloudy
        122: "󰖐",  # Overcast
        143: "󰖑",  # Mist
        176: "󰖗",  # Patchy rain
        179: "󰖘",  # Patchy snow
        182: "󰙿",  # Patchy sleet
        185: "󰙿",  # Patchy freezing drizzle
        200: "󰖓",  # Thundery outbreaks
        227: "󰼶",  # Blowing snow
        230: "󰼶",  # Blizzard
        248: "󰖑",  # Fog
        260: "󰖑",  # Freezing fog
        263: "󰖗",  # Patchy light drizzle
        266: "󰖗",  # Light drizzle
        281: "󰙿",  # Freezing drizzle
        284: "󰙿",  # Heavy freezing drizzle
        293: "󰖗",  # Patchy light rain
        296: "󰖗",  # Light rain
        299: "󰖖",  # Moderate rain at times
        302: "󰖖",  # Moderate rain
        305: "󰖖",  # Heavy rain at times
        308: "󰖖",  # Heavy rain
        311: "󰙿",  # Light freezing rain
        314: "󰙿",  # Moderate/heavy freezing rain
        317: "󰙿",  # Light sleet
        320: "󰙿",  # Moderate/heavy sleet
        323: "󰖘",  # Patchy light snow
        326: "󰖘",  # Light snow
        329: "󰼴",  # Patchy moderate snow
        332: "󰼴",  # Moderate snow
        335: "󰼶",  # Patchy heavy snow
        338: "󰼶",  # Heavy snow
        350: "󰙿",  # Ice pellets
        353: "󰖗",  # Light rain shower
        356: "󰖖",  # Moderate/heavy rain shower
