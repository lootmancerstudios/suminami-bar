    }
    return icons.get(code, "َ°–گ")

def format_output(data):
    """Format weather data for waybar output"""
    try:
        current = data["current_condition"][0]
        location = data["nearest_area"][0]
        weather = data["weather"][0]
        astro = weather["astronomy"][0]

        # Current conditions
        temp_c = current["temp_C"]
        feels_c = current["FeelsLikeC"]
        humidity = current["humidity"]
        wind_kmph = current["windspeedKmph"]
        wind_dir = current["winddir16Point"]
        condition = current["weatherDesc"][0]["value"]
        code = current["weatherCode"]

        # Location
        city = location["areaName"][0]["value"]
        region = location["region"][0]["value"]

        # Astronomy
        sunrise = astro["sunrise"]
        sunset = astro["sunset"]

        # Theme colors (from colors.sh)
        colors = load_theme_colors()
        accent = colors["accent"]
        highlight = colors["highlight"]
        gray = colors["muted"]
        white = colors["fg"]

        # Build tooltip with Pango markup
        tooltip_lines = [
            f"<span color='{accent}'><b>{city}</b></span>, <span color='{gray}'>{region}</span>",
            f"<span color='{white}'>{condition}</span>",
            "",
            f"<span color='{gray}'>Feels like:</span> <span color='{highlight}'>{feels_c}آ°C</span>",
            f"<span color='{gray}'>Humidity:</span> <span color='{white}'>{humidity}%</span>",
            f"<span color='{gray}'>Wind:</span> <span color='{white}'>{wind_kmph} km/h {wind_dir}</span>",
            "",
            f"<span color='{highlight}'>َ°–¨ {sunrise}</span>   <span color='{accent}'>َ°–› {sunset}</span>",
        ]
        tooltip = "\n".join(tooltip_lines)

        # Icon
        icon = get_icon(code)

        return {
            "text": f"{icon} {temp_c}آ°",
            "tooltip": tooltip,
            "class": "weather",
            "success": True
        }

    except (KeyError, IndexError):
        return None

def main():
    # Check cache first
    cached = load_cache()
    if cached:
        # Output cached data (without success flag in output)
        output = {k: v for k, v in cached.items() if k != "success"}
        print(json.dumps(output))
        return

    # Fetch fresh data
    data = fetch_weather()

    if data:
        output = format_output(data)
        if output:
            save_cache(output)
            # Output without success flag
            clean_output = {k: v for k, v in output.items() if k != "success"}
            print(json.dumps(clean_output))
            return

    # Failure - output error (don't cache failures)
    print(json.dumps({"text": "َ°–گ --", "tooltip": "Weather unavailable", "class": "error"}))

if __name__ == "__main__":
    main()
