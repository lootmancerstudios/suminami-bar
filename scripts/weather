    }
    return icons.get(code, "󰖐")

def resolve_city(data):
    """Get display city name: configured location > Nominatim reverse geocode > raw query"""
    configured = get_weather_location()
    if configured:
        return configured

    # Try location cache first
    cached_city = load_location_cache()
    if cached_city:
        return cached_city

    # Parse lat/lon from wttr.in response and reverse geocode
    query_str = data.get("request", [{}])[0].get("query", "")
    lat, lon = parse_latlon(query_str)
    if lat is not None:
        city = reverse_geocode(lat, lon)
        if city:
            save_location_cache(city)
            return city

    # Fallback: raw query string
    return query_str if query_str else "Unknown"

def format_output(data):
    try:
        current = data["current_condition"][0]
        weather = data["weather"][0]
        astro = weather["astronomy"][0]

        temp_c = current["temp_C"]
        feels_c = current["FeelsLikeC"]
        humidity = current["humidity"]
        wind_kmph = current["windspeedKmph"]
        wind_dir = current["winddir16Point"]
        condition = current["weatherDesc"][0]["value"]
        code = current["weatherCode"]
        sunrise = astro["sunrise"]
        sunset = astro["sunset"]

        city = resolve_city(data)

        colors = load_theme_colors()
        accent = colors["accent"]
        highlight = colors["highlight"]
        gray = colors["muted"]
        white = colors["fg"]

        tooltip_lines = [
            f"<span color='{accent}'><b>{city}</b></span>",
            f"<span color='{white}'>{condition}</span>",
            "",
            f"<span color='{gray}'>Feels like:</span> <span color='{highlight}'>{feels_c}°C</span>",
            f"<span color='{gray}'>Humidity:</span> <span color='{white}'>{humidity}%</span>",
            f"<span color='{gray}'>Wind:</span> <span color='{white}'>{wind_kmph} km/h {wind_dir}</span>",
            "",
            f"<span color='{highlight}'>󰖨 {sunrise}</span>   <span color='{accent}'>󰖛 {sunset}</span>",
        ]
        tooltip = "\n".join(tooltip_lines)
        icon = get_icon(code)

        return {
            "text": f"{icon} {temp_c}°",
            "tooltip": tooltip,
            "class": "weather",
            "success": True
        }

    except (KeyError, IndexError):
        return None

def main():
    cached = load_cache()
    if cached:
        output = {k: v for k, v in cached.items() if k != "success"}
        print(json.dumps(output))
        return

    data = fetch_weather()
    if data:
        output = format_output(data)
        if output:
            save_cache(output)
            clean_output = {k: v for k, v in output.items() if k != "success"}
            print(json.dumps(clean_output))
            return

    print(json.dumps({"text": "󰖐 --", "tooltip": "Weather unavailable", "class": "error"}))

if __name__ == "__main__":
    main()
