#!/usr/bin/env python3
"""Weather widget for Waybar using wttr.in (auto-detects location via IP)

Caches successful results for 10 minutes. On failure, retries every interval.
"""

import json
import os
import time
import urllib.parse
import urllib.request

CACHE_FILE = "/tmp/waybar-weather-cache"
CACHE_MAX_AGE = 600  # 10 minutes - only fetch if cache older than this
SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
COLORS_FILE = os.path.join(SCRIPT_DIR, "colors.sh")
CONFIG_FILE = os.path.expanduser("~/.config/waybar/suminami.conf")

def load_theme_colors():
    """Load colors from colors.sh"""
    colors = {
        "accent": "#D27E99",
        "fg": "#DCD7BA",
        "muted": "#727169",
        "system": "#98BB6C",
        "audio": "#7FB4CA",
        "highlight": "#7FB4CA",
        "weather": "#A3D4D5",
        "warning": "#E6C384",
        "critical": "#E46876",
    }
    try:
        if os.path.exists(COLORS_FILE):
            with open(COLORS_FILE, 'r') as f:
                for line in f:
                    line = line.strip()
                    if line.startswith("COLOR_"):
                        parts = line.split("=", 1)
                        if len(parts) == 2:
                            key = parts[0].replace("COLOR_", "").lower()
                            value = parts[1].strip('"\'')
                            colors[key] = value
    except Exception:
        pass
    return colors

def load_cache():
    """Load cached weather data if valid"""
    try:
        if os.path.exists(CACHE_FILE):
            mtime = os.path.getmtime(CACHE_FILE)
            age = time.time() - mtime
            if age < CACHE_MAX_AGE:
                with open(CACHE_FILE, 'r') as f:
                    data = json.load(f)
                    # Only use cache if it was successful (has actual temp)
                    if data.get("success"):
                        return data
    except Exception:
        pass
    return None

def save_cache(data):
    """Save weather data to cache"""
    try:
        with open(CACHE_FILE, 'w') as f:
            json.dump(data, f)
    except Exception:
        pass

def get_weather_location():
    """Read weather_location from config file"""
    try:
        if os.path.exists(CONFIG_FILE):
            with open(CONFIG_FILE, 'r') as f:
                for line in f:
                    if line.startswith('weather_location='):
                        location = line.split('=', 1)[1].strip()
                        if location:
                            return location
    except Exception:
        pass
    return None

def fetch_weather():
    """Fetch weather from wttr.in"""
    try:
        location = get_weather_location()
        if location:
            # URL-encode the location
            location = urllib.parse.quote(location)
            url = f"https://wttr.in/{location}?format=j1"
        else:
            url = "https://wttr.in/?format=j1"
        req = urllib.request.Request(url, headers={"User-Agent": "curl/8.0"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode())
    except Exception:
        return None

def get_icon(code):
    """Map weather codes to nerd font icons"""
    code = int(code)
    icons = {
        113: "َ°–™",  # Clear/Sunny
        116: "َ°–•",  # Partly cloudy
        119: "َ°–گ",  # Cloudy
        122: "َ°–گ",  # Overcast
        143: "َ°–‘",  # Mist
        176: "َ°–—",  # Patchy rain
        179: "َ°–ک",  # Patchy snow
        182: "َ°™؟",  # Patchy sleet
        185: "َ°™؟",  # Patchy freezing drizzle
        200: "َ°–“",  # Thundery outbreaks
        227: "َ°¼¶",  # Blowing snow
        230: "َ°¼¶",  # Blizzard
        248: "َ°–‘",  # Fog
        260: "َ°–‘",  # Freezing fog
        263: "َ°–—",  # Patchy light drizzle
        266: "َ°–—",  # Light drizzle
        281: "َ°™؟",  # Freezing drizzle
        284: "َ°™؟",  # Heavy freezing drizzle
        293: "َ°–—",  # Patchy light rain
        296: "َ°–—",  # Light rain
        299: "َ°––",  # Moderate rain at times
        302: "َ°––",  # Moderate rain
        305: "َ°––",  # Heavy rain at times
        308: "َ°––",  # Heavy rain
        311: "َ°™؟",  # Light freezing rain
        314: "َ°™؟",  # Moderate/heavy freezing rain
        317: "َ°™؟",  # Light sleet
        320: "َ°™؟",  # Moderate/heavy sleet
        323: "َ°–ک",  # Patchy light snow
        326: "َ°–ک",  # Light snow
        329: "َ°¼´",  # Patchy moderate snow
        332: "َ°¼´",  # Moderate snow
